{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowHCPTerraformStackOIDC",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::735910966814:oidc-provider/app.terraform.io"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "app.terraform.io:aud": "aws.workload.identity"
        },
        "StringLike": {
          "app.terraform.io:sub": "organization:ayazi-ped:project:ped-demo:stack:ho-ped:deployment:*"
        }
      }
    }
  ]
}
